<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <display-name>CoffeeLux Management System</display-name>
    <servlet-mapping>
        <servlet-name>IngredientController</servlet-name>
        <url-pattern>/ingredient</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PurchaseOrderController</servlet-name>
        <url-pattern>/po</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>IssueController</servlet-name>
        <url-pattern>/issue</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
    <!-- User API Controller -->
    <servlet>
        <servlet-name>UserController</servlet-name>
        <servlet-class>controller.UserController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>IngredientController</servlet-name>
        <servlet-class>controller.IngredientController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PurchaseOrderController</servlet-name>
        <servlet-class>controller.PurchaseOrderController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>IssueController</servlet-name>
        <servlet-class>controller.IssueController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserController</servlet-name>
        <url-pattern>/api/user/*</url-pattern>
    </servlet-mapping>
    <!-- Product API Controller -->
    <servlet>
        <servlet-name>ProductController</servlet-name>
        <servlet-class>controller.ProductController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductController</servlet-name>
        <url-pattern>/api/product/*</url-pattern>
    </servlet-mapping>
    <!-- User Page Controller -->
    <servlet>
        <servlet-name>UserPageController</servlet-name>
        <servlet-class>controller.UserPageController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserPageController</servlet-name>
        <url-pattern>/users</url-pattern>
    </servlet-mapping>

    <!-- User Shop List Controller -->
    <servlet>
        <servlet-name>UserShopListController</servlet-name>
        <servlet-class>controller.UserShopListController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserShopListController</servlet-name>
        <url-pattern>/user/shoplist</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UserShopListController</servlet-name>
        <url-pattern>/user/shoplist/*</url-pattern>
    </servlet-mapping>

    <!-- Reset Password Controller -->
    <servlet>
        <servlet-name>ResetPasswordController</servlet-name>
        <servlet-class>controller.ResetPasswordController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResetPasswordController</servlet-name>
        <url-pattern>/reset-pass</url-pattern>
    </servlet-mapping>

    <!-- Login Controller -->
    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>controller.LoginController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Order Controller -->
    <servlet>
        <servlet-name>OrderController</servlet-name>
        <servlet-class>controller.OrderController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderController</servlet-name>
        <url-pattern>/orders</url-pattern>
    </servlet-mapping>
</web-app>
